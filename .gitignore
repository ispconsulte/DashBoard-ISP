# =========================================================
# Projeto (Next.js + Python) — .gitignore organizado
# =========================================================

# -------------------------
# Node / Yarn / PNPM
# -------------------------
node_modules/
frontend/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -------------------------
# Next.js / Build output
# -------------------------
.next/
out/
build/
dist/
.vite/

# Se existir Next dentro de subpasta (ex.: /frontend)
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
backend/supabase/.temp/

# -------------------------
# Coverage / Test
# -------------------------
coverage/
.coverage
coverage.xml
.pytest_cache/
.mypy_cache/
*.tsbuildinfo

# -------------------------
# Env / Secrets
# -------------------------
.env
.env.*
!.env.example
!.env.local.example
!.env.example.frontend

# Se você usa essas variações localmente e NÃO quer versionar:
.env.local
.env.development
.env.production

# -------------------------
# Vercel
# -------------------------
.vercel/
.codex_tmp/

# -------------------------
# TypeScript / Next extras
# -------------------------
next-env.d.ts

# -------------------------
# Python
# -------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

venv/
.venv/
env/

# Flask / runtime
instance/
var/

# -------------------------
# Logs / Uploads / Runtime
# -------------------------
# (não confundir com .git/logs que o Git usa)
logs/
*.log
*.tmp

uploads/

# -------------------------
# OS / IDE
# -------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/

# -------------------------
# Certificados / Chaves
# -------------------------
*.pem
*.key
*.p12
*.pfx

# -------------------------
# Binários comuns (evitar subir)
# -------------------------
*.exe

# -------------------------
# Dados locais / configs locais
# -------------------------
config_local.json
*.db
*.sqlite
*.sqlite3

# -------------------------
# Pastas legadas / específicas (se for só local)
# -------------------------
Projeto-IXC/backup/
Projeto-IXC/resource/Documentation/
backup/
.vercel

.vercel

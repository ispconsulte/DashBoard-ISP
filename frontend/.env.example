# Copie este arquivo para .env.local e preencha os valores antes de subir o projeto.
# O Next.js lï¿½ automaticamente .env.local na raiz, mas os scripts jï¿½ carregam via dotenv para reforï¿½ar.

# FRONTEND (Next.js) - variï¿½veis pï¿½blicas
NEXT_PUBLIC_SUPABASE_URL=https://sua-instancia.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=troque_a_chave_publica_aqui
NEXT_PUBLIC_ADMIN_PASSCODE=ADMIN-ACCESS
NEXT_PUBLIC_DEFAULT_ADMIN_EMAIL=admin@isp.test
NEXT_PUBLIC_DEFAULT_ADMIN_PASSWORD=admin123
NEXT_PUBLIC_DEFAULT_ADMIN_NAME=Administrador

# SUPABASE - segredos/variï¿½veis do lado do servidor
SUPABASE_SERVICE_ROLE_KEY=troque_a_service_role_aqui
SUPABASE_URL=https://sua-instancia.supabase.co

# BACKEND (Flask/API)
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5001
LOG_DIR=logs
LOG_LEVEL=INFO
FLASK_API_KEY=troque_este_token_seguro

# IXC / Comodato (ajuste conforme a instï¿½ncia em uso)
IXC_HOST=https://ixc.example.com/webservice/v1
IXC_USER=
IXC_PASS=
IXC_COOKIE=
# Preferencial no Web/API Next (milissegundos)
IXC_TIMEOUT_MS=8000
# Compatibilidade legada (segundos, convertido para ms no Web)
IXC_TIMEOUT=8
IXC_VERIFY_SSL=1
IXC_ID_PRODUTO=1128
IXC_ID_UNIDADE=1
IXC_ID_ALMOX=39
IXC_FILIAL_ID=1
IXC_ID_CLASS_TRIB=1
IXC_UNIDADE_SIGLA=MC
IXC_TIPO=S
IXC_ESTOQUE=S
IXC_FATOR_CONVERSAO=1.000000000
IXC_VALOR_UNITARIO=0.10

